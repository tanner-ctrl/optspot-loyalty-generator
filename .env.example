# ─── Anthropic API ────────────────────────────────────────────────────────────
# Add your Anthropic API key here to enable AI-generated messages.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_key_here

# ─── Demo mode ────────────────────────────────────────────────────────────────
# Leave DEMO_MODE=true to explore the app without an API key.
# Messages will come from a curated template pool instead of Claude.
# Set to false (or remove this line) once your ANTHROPIC_API_KEY is added.
DEMO_MODE=true
